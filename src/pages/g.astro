---
import { getTodaysGif } from "../data/gifs";

const gif = getTodaysGif();
const siteUrl = import.meta.env.SITE ?? "https://dzien.scooby.boo";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta property="og:type" content="video.other" />
    <meta property="og:video" content={gif.url} />
    <meta property="og:video:secure_url" content={gif.url} />
    <meta property="og:video:type" content="video/mp4" />
  </head>

  <body>
  </body>
</html>
